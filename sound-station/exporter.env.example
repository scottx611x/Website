# Copy to exporter.env on the Pi and fill in the scoped exporter key.
# (exporter.env is git-ignored — it holds a real secret.)
BIRDS_S3_BUCKET=birds-scott-ouellette
BNG_URL=http://localhost:8080
BNG_CLIPS_DIR=/home/scott/birdnet-go/data/clips
AWS_DEFAULT_REGION=us-east-1
# The birdpi-sound-exporter key (write-only to birds/sounds/*). NOT your
# personal master keys — mint the scoped user with `tofu apply` in infra/website.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
