{
    "production": {
        "app_function": "index.app",
        "timeout_seconds": 300,
        "memory_size": 1024,
        "aws_region": "us-east-1",
        "s3_bucket": "zappa-0206au0bc",
        "domain": "www.scott-ouellette.com",
        "environment_variables": {
            "BIRDS_USE_S3": "1",
            "BIRDS_S3_BUCKET": "birds-scott-ouellette"
        },
        "extra_permissions": [
            {
                "Effect": "Allow",
                "Action": ["s3:PutObject", "s3:GetObject"],
                "Resource": "arn:aws:s3:::birds-scott-ouellette/birds/*"
            },
            {
                "Effect": "Allow",
                "Action": ["ssm:GetParameter", "ssm:PutParameter"],
                "Resource": "arn:aws:ssm:us-east-1:*:parameter/birds/*"
            }
        ],
        "events": [
            {
                "function": "birds.scheduled_sync",
                "expression": "rate(1 day)"
            }
        ]
    }
}
